# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_ENDPOINT=https://models.inference.ai.azure.com
LLM_API_KEY=your_github_pat_here

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_ENDPOINT=https://models.inference.ai.azure.com
EMBEDDING_API_KEY=your_github_pat_here

# Cognee Configuration
COGNEE_API_KEY=your_cognee_api_key_here
COGNEE_SERVICE_URL=https://api.cognee.ai
COGNEE_SKIP_CONNECTION_TEST=true

# Optional tuning
EMBEDDING_BATCH_SIZE=5
EMBEDDING_MAX_TOKENS=2000
LLM_MAX_RETRIES=3
LLM_INSTRUCTOR_MODE=tool_call
